-- Helper function to check health via Attributes (primary), ValueObjects, or Humanoid (fallback)
local function getEnemyHealth(enemy)
    if not enemy or not enemy.Parent then return 0 end
    
    -- 1. Check common death attributes (including specific "EnemyDead" attribute from target game)
    if enemy:GetAttribute("EnemyDead") == true 
        or enemy:GetAttribute("IsDead") == true 
        or enemy:GetAttribute("Dead") == true 
        or enemy:GetAttribute("Killed") == true then
        return 0
    end
    
    -- 2. Check health attributes (including specific "HealthReal" attribute from target game)
    local hpAttribute = enemy:GetAttribute("HealthReal") 
        or enemy:GetAttribute("Health") 
        or enemy:GetAttribute("HP") 
        or enemy:GetAttribute("HealthValue")
        
    if hpAttribute then
        return tonumber(hpAttribute)
    end
    
    -- 3. Check for ValueObject named "Health" or "HP" recursively inside the model
    local hpValueObj = enemy:FindFirstChild("Health", true) 
        or enemy:FindFirstChild("HP", true) 
        or enemy:FindFirstChild("HealthValue", true)
        or enemy:FindFirstChild("HPValue", true)
        
    if hpValueObj and (hpValueObj:IsA("NumberValue") or hpValueObj:IsA("IntValue")) then
        return hpValueObj.Value
    end
    
    -- 4. Check for Humanoid recursively inside the model
    local humanoid = enemy:FindFirstChildWhichIsA("Humanoid", true)
    if humanoid then
        return humanoid.Health
    end
    
    return nil -- No health metrics found
end

-- Safely checks if an enemy is alive based on health or status
local function isEnemyAlive(enemy)
    if not enemy or not enemy.Parent then return false end
    
    -- Check if explicitly dead by attribute (including specific "EnemyDead" attribute from target game)
    if enemy:GetAttribute("EnemyDead") == true 
        or enemy:GetAttribute("IsDead") == true 
        or enemy:GetAttribute("Dead") == true 
        or enemy:GetAttribute("Killed") == true then
        return false
    end
    
    local health = getEnemyHealth(enemy)
    if health ~= nil then
        return health > 0
    end
    
    -- Fallback: check humanoid if health function returned nil
    local humanoid = enemy:FindFirstChildWhichIsA("Humanoid", true)
    if humanoid then
        return humanoid.Health > 0
    end
    
    -- If no health indicator exists, assume alive
    return true
end

