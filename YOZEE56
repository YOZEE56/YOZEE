-- ==========================================
-- 📦 Tab 5: Misc (Smart Time Rewards)
-- ==========================================
local MiscTab = Window:Tab({ Title = "Misc", Icon = "box" })

local TimeMonitor = MiscTab:Button({
    Title = "Next Reward: Loading...",
    Desc = "",
    Icon = "clock"
})

task.spawn(function()
    while task.wait(1) do
        pcall(function()
            local timePlayed = Omni.Data.TimeRewards.TimePlayed
            local claimed = Omni.Data.TimeRewards.Claimed
            local shared = Omni.Shared.TimeRewards
            
            local nextIndex = nil
            local reqTime = 0
            
            for i = 1, 7 do
                if not claimed[tostring(i)] then
                    nextIndex = i
                    reqTime = shared[i] and shared[i].Time or 0
                    break
                end
            end
            
            if nextIndex then
                local diff = reqTime - timePlayed
                if diff <= 0 then
                    TimeMonitor:SetTitle("Next Reward (" .. nextIndex .. "): READY TO CLAIM!")
                    TimeMonitor:SetDesc("กล่องพร้อมรับแล้ว!")
                else
                    local h = math.floor(diff / 3600)
                    local m = math.floor((diff % 3600) / 60)
                    local s = math.floor(diff % 60)
                    TimeMonitor:SetTitle(string.format("Next Reward (%d): %02dh %02dm %02ds", nextIndex, h, m, s))
                    TimeMonitor:SetDesc("เวลาออนไลน์สะสม: " .. math.floor(timePlayed) .. " วินาที")
                end
            else
                TimeMonitor:SetTitle("Time Rewards: All Claimed!")
                TimeMonitor:SetDesc("รับของรางวัลครบ 7")
            end
        end)
    end
end)

local autoClaimTimeRewardEnabled = false
MiscTab:Toggle({
    Title = "Auto Claim Time Rewards",
    Desc = "รับเฉพาะกล่องที่พร้อม",
    Value = false,
    Callback = function(state)
        autoClaimTimeRewardEnabled = state
        if autoClaimTimeRewardEnabled then
            task.spawn(function()
                local remoteEvent = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
                while autoClaimTimeRewardEnabled do
                    pcall(function()
                        local timePlayed = Omni.Data.TimeRewards.TimePlayed
                        local claimed = Omni.Data.TimeRewards.Claimed
                        local shared = Omni.Shared.TimeRewards
                        
                        for i = 1, 7 do
                            if not claimed[tostring(i)] then
                                local reqTime = shared[i] and shared[i].Time or math.huge
                                if timePlayed >= reqTime then
                                    remoteEvent:FireServer({{ "General", "TimeRewards", "Claim", i }, "\x02"})
                                    task.wait(1.5)
                                end
                            end
                        end
                    end)
                    task.wait(3)
                end
            end)
        end
    end
})

