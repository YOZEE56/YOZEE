-- ==========================================
-- 🔨 Tab: Forge (Full Restoration)
-- ==========================================
local memUnits, unitLockStatus, selectedMemUUID = {}, {}, ""
local StatusLabel = Tabs.Forge:AddParagraph({ Title = "Selected Unit Status", Content = "Please scan and select a unit" })

local ForgeDropdown = Tabs.Forge:AddDropdown("ForgeDropdown", {
    Title = "Select Unit", Values = {"Waiting for scan..."}, Multi = false, Default = 1,
    Callback = function(Value)
        selectedMemUUID = memUnits[Value] or ""
        StatusLabel:SetTitle("Unit Status: " .. (unitLockStatus[Value] or "Unknown"))
    end
})

Tabs.Forge:AddButton({
    Title = "🔍 Scan Units",
    Callback = function()
        task.spawn(function()
            local options = {}
            table.clear(memUnits); table.clear(unitLockStatus)
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" and rawget(v, "Inventory") and rawget(rawget(v, "Inventory"), "Units") then
                    for uid, unitData in pairs(v.Inventory.Units) do
                        local name, isLocked = tostring(unitData.Name), rawget(unitData, "Locked")
                        local display = name .. " | " .. string.sub(tostring(uid), 1, 6)
                        memUnits[display] = uid
                        unitLockStatus[display] = isLocked and "Locked 🔒" or "Unlocked 🔓"
                        table.insert(options, display)
                    end
                end
            end
            if #options > 0 then table.sort(options) ForgeDropdown:SetValues(options) end
        end)
    end
})

