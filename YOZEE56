local ClaimT = Tabs.Misc:AddToggle("AutoClaim", {Title = "Auto Claim & Reset Rewards", Default = false})
ClaimT:OnChanged(function()
    task.spawn(function()
        local remote = game:GetService("ReplicatedStorage").BridgeNet.dataRemoteEvent
        while ClaimT.Value do
            pcall(function()
                local data = Omni.Data.TimeRewards
                for i = 1, 7 do
                    if not data.Claimed[tostring(i)] and data.TimePlayed >= Omni.Shared.TimeRewards[i].Time then
                        remote:FireServer({{ "General", "TimeRewards", "Claim", i }, "\x02"})
                        task.wait(1.5)
                    end
                end
                if data.Claimed["7"] then remote:FireServer({{[1] = "General", [2] = "TimeRewards", [3] = "Reset"}, "\x02"}) end
            end)
            task.wait(3)
        end
    end)
end)

