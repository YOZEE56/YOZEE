for _, cfg in ipairs(worlds) do
    local Toggle = Tabs.OpFarm:AddToggle("Farm"..cfg.name, {Title = cfg.name, Default = false})
    Toggle:OnChanged(function()
        if Toggle.Value then
            task.spawn(function()
                local remote = game:GetService("ReplicatedStorage").BridgeNet.dataRemoteEvent
                while Toggle.Value do
                    -- Smart Teleport Check
                    if Omni.Data.Map ~= cfg.MapName or Omni.Data.Zone ~= cfg.ZoneIndex then
                        remote:FireServer({{ "Player", "Teleport", "Teleport", cfg.MapName, cfg.ZoneIndex, n = 5 }, "\x02"})
                        repeat task.wait(1) until (Omni.Data.Map == cfg.MapName and Omni.Data.Zone == cfg.ZoneIndex) or not Toggle.Value
                    end
                    -- Point Loop
                    for _, target in ipairs(cfg.points) do
                        if not Toggle.Value then break end
                        if Omni.Data.Map ~= cfg.MapName or Omni.Data.Zone ~= cfg.ZoneIndex then break end
                        local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if hrp and game.Players.LocalPlayer.Character.Humanoid.Health > 0 then
                            hrp.CFrame = target
                            task.wait(opWaitTime)
                        end
                    end
                end
            end)
        end
    end)
end

