            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local isLeaveButton = false
                
                -- Check by instance name
                if string.find(string.lower(child.Name), "leave") then
                    isLeaveButton = true
                end
                
                -- Check by text label content
                if child:IsA("TextButton") then
                    local success, text = pcall(function() return child.Text end)
                    if success and text and string.find(string.lower(text), "leave") then
                        isLeaveButton = true
                    end
                end
                
                if isLeaveButton then
                    pcall(function()
                        child:Activate()
                    end)
                    -- Also trigger virtual click connections if the executor supports firesignal
                    if firesignal then
                        pcall(function() firesignal(child.MouseButton1Click) end)
                        pcall(function() firesignal(child.MouseButton1Down) end)
                        pcall(function() firesignal(child.Activated) end)
                    end
                end
            end
        end
    end
    
    return true
end


