-- ==========================================
-- 🎰 Tab 3: Spin
-- ==========================================
local SpinTab = Window:Tab({
    Title = "Spin",
    Icon = "rotate-cw"
})

local autoSpinDragonWishEnabled = false

SpinTab:Toggle({
    Title = "Auto Spin Dragon Wish",
    Desc = "กดสุ่มนะคับ",
    Value = false,
    Callback = function(state)
        autoSpinDragonWishEnabled = state
        
        if autoSpinDragonWishEnabled then
            task.spawn(function()
                local remoteEvent = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
                
                while autoSpinDragonWishEnabled do
                    remoteEvent:FireServer({
                        {
                            "General",
                            "Roulette",
                            "Roll",
                            "Dragon Wish",
                            n = 4
                        },
                        "\x02"
                    })
                    task.wait(0.5) -- หน่วงเวลาป้องกันโดนเตะข้อหาแสปม
                end
            end)
        end
    end
})

-- ==========================================
-- ⚙️ Tab 4: Settings
-- ==========================================
local SettingsTab = Window:Tab({
    Title = "Settings",
    Icon = "settings"
})

SettingsTab:Keybind({
    Title = "Toggle UI",
    Desc = "Set your UI toggle bind.",
    Value = "RightShift",
    Callback = function(Key)
        Window:SetToggleKey(Enum.KeyCode[Key])
        WindUI:Notify({
            Title = "Settings",
            Content = "Toggle key set to " .. Key,
            Duration = 3,
            Icon = "settings"
        })
    end
})

SettingsTab:Button({
    Title = "Unload UI",
    Desc = "Complete",
    Icon = "log-out",
    Callback = function()
        -- Stop all loops before unloading to prevent memory leaks or crashes
        autoRollHakiEnabled = false
        autoRollFruitEnabled = false
        autoRollSwordEnabled = false
        autoRollRaceEnabled = false
        autoRollDragonPowerEnabled = false
        autoRollSlimePowerEnabled = false
        autoSpinDragonWishEnabled = false
        Window:Destroy()
    end
})
