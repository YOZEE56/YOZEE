-- Hook Window:Tab to modify Section behavior (remove collapse/expand chevrons, make sections always open)
local originalTab = Window.Tab
Window.Tab = function(self, tabConfig)
    local tab = originalTab(self, tabConfig)
    
    local originalSection = tab.Section
    tab.Section = function(tabSelf, sectionConfig)
        -- Force the section to start opened
        sectionConfig.Opened = true
        
        local section = originalSection(tabSelf, sectionConfig)
        
        -- Override section.Close to be a no-op so clicking the header does not collapse it
        section.Close = function() end
        
        -- Set IconSize to -8 so that UpdateTitleSize does not reserve space for the chevron
        section.IconSize = -8
        
        -- Hide the chevron icon as soon as it becomes visible
        task.spawn(function()
            local topFrame = section.ElementFrame and section.ElementFrame:FindFirstChild("Top")
            if topFrame then
                local chevron = topFrame:FindFirstChildWhichIsA("Frame")
                if chevron then
                    chevron.Visible = false
                    chevron:GetPropertyChangedSignal("Visible"):Connect(function()
                        if chevron.Visible then
                            chevron.Visible = false
                        end
                    end)
                end
            end
        end)
        
        return section
    end
    
    return tab
end


