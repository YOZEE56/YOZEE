                currentRunningTask = "Auto Farm"
            end
            
            -- Find index of current running task in queue
            local currentIndex = 99
            for i = 1, 5 do
                if priorityQueue[i] == currentRunningTask then
                    currentIndex = i
                    break
                end
            end
            
            -- Override: If bestTask has higher priority (smaller index) than current task, leave!
            if bestIndex < currentIndex then
                -- Only leave if we are actually inside an arena
                if currentArena ~= "None" and currentRunningTask ~= bestTask then
                    print("[Priority Queue] Higher priority task (" .. bestTask .. ") is available! Leaving current match (" .. currentRunningTask .. ").")
