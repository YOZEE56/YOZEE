for _, cfg in ipairs(worlds) do
    local isEnabled = false
    local FarmToggle = OpTab:Toggle({
        Title = cfg.name,
        Desc = "Check & Farm",
        Value = false,
        Callback = function(state)
            isEnabled = state
            if isEnabled then
                task.spawn(function()
                    local remote = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
                    while isEnabled do
                        if Omni.Data.Map ~= cfg.MapName or Omni.Data.Zone ~= cfg.ZoneIndex then
                            -- Firing Teleport Remote
                            remote:FireServer({{ "Player", "Teleport", "Teleport", cfg.MapName, cfg.ZoneIndex, n = 5 }, "\x02"})
                            repeat task.wait(1) until (Omni.Data.Map == cfg.MapName and Omni.Data.Zone == cfg.ZoneIndex) or not isEnabled
                        end
                        for _, targetCFrame in ipairs(cfg.points) do
                            if not isEnabled then break end
                            if Omni.Data.Map ~= cfg.MapName or Omni.Data.Zone ~= cfg.ZoneIndex then break end
                            local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if hrp then hrp.CFrame = targetCFrame end
                            task.wait(opWaitTime)
                        end
                    end
                end)
            end
        end
    })
    if myConfig then myConfig:Register("Farm_"..cfg.name:gsub(" ", "_"), FarmToggle) end
end

