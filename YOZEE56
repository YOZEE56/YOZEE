-- ⚔️ Tab: Raid (Join & Attribute Farm)
-- ==========================================
local AutoJoinRaid = Tabs.Raid:AddToggle("AutoJoinRaid", {Title = "1. Auto Join Raid", Default = false})
AutoJoinRaid:OnChanged(function()
    task.spawn(function()
        local remote = game:GetService("ReplicatedStorage").BridgeNet.dataRemoteEvent
        while AutoJoinRaid.Value do
            local currentMode = Omni and Omni.Data and Omni.Data.Mode or ""
            if currentMode ~= "Tempest Invasion" then
                remote:FireServer({{"General","Gamemodes","Join","Tempest Invasion",n = 4},"\x02"})
                task.wait(5)
            else task.wait(2) end
        end
    end)
end)

AutoFarmRaid = Tabs.Raid:AddToggle("AutoFarmRaid", {Title = "2. Auto Farm Raid", Default = false})
AutoFarmRaid:OnChanged(function()
    task.spawn(function()
        local hasWaited = false
        while AutoFarmRaid.Value do
            local raidPath = workspace:FindFirstChild("Server") and workspace.Server:FindFirstChild("Enemies") and workspace.Server.Enemies:FindFirstChild("Gamemodes") and workspace.Server.Enemies.Gamemodes:FindFirstChild("Tempest Invasion")
            if raidPath then
                if not hasWaited then task.wait(3.5) hasWaited = true end
                for _, enemy in pairs(raidPath:GetChildren()) do
                    if not AutoFarmRaid.Value then break end
                    if (enemy:GetAttribute("Health") or 0) > 0 then
                        while AutoFarmRaid.Value and enemy.Parent == raidPath and (enemy:GetAttribute("Health") or 0) > 0 do
                            local myChar = game.Players.LocalPlayer.Character
                            local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                            if myHrp then
                                local targetCF = nil
                                if enemy:IsA("Model") then targetCF = enemy.PrimaryPart and enemy.PrimaryPart.CFrame or enemy:GetPivot()
                                elseif enemy:IsA("BasePart") then targetCF = enemy.CFrame end
                                if targetCF then myChar:PivotTo(targetCF * CFrame.new(0, 0, 3)) end
                            end
                            task.wait(0.2)
                        end
                    end
                end
            else hasWaited = false end
            task.wait(0.1)
        end
    end)
end)

