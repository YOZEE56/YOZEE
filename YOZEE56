-- Debug function to print all attributes and values of target in F9 Developer Console
local function debugAttributes(enemy)
    if enemy then
        print("[WindUI Debug] --- Target Locked: " .. enemy.Name .. " ---")
        -- Print attributes
        for attributeName, attributeValue in pairs(enemy:GetAttributes()) do
            print("  Attribute: " .. attributeName .. " = " .. tostring(attributeValue))
        end
        -- Print ValueObjects
        for _, child in ipairs(enemy:GetDescendants()) do
            if child:IsA("NumberValue") or child:IsA("IntValue") then
                print("  ValueObject: " .. child.Name .. " = " .. tostring(child.Value))
            end
        end
        -- Print Humanoid Health
        local humanoid = enemy:FindFirstChildWhichIsA("Humanoid", true)
        if humanoid then
            print("  Humanoid Health: " .. tostring(humanoid.Health) .. " / " .. tostring(humanoid.MaxHealth))
        else
            print("  No Humanoid found recursively.")
        end
        print("[WindUI Debug] ---------------------------------------------")
    end
end

-- Helper function to parse current wave number from active ScreenGui (dynamic path to support custom GUI names)
local function getCurrentWave()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui.Enabled then
            local main = gui:FindFirstChild("Main")
            local waveObj = main and (main:FindFirstChild("Wave") or main:FindFirstChild("Room"))
            if waveObj then
                local success, text = pcall(function() return waveObj.Text end)
                if success and text then
                    -- Match the current wave number from "Wave 14/100" or "Room 14" format
                    local waveNum = string.match(text, "Wave%s*(%d+)") or string.match(text, "Room%s*(%d+)") or string.match(text, "(%d+)")
                    return waveNum and tonumber(waveNum)
                end
            end
        end
    end
    return nil
end

-- Helper function to click a GuiButton safely (fail-safe fallback)
local function pressGuiButton(button)
    if button and button:IsA("GuiButton") then
        pcall(function()
            button:Activate()
        end)
        if firesignal then
            pcall(function() firesignal(button.MouseButton1Click) end)
            pcall(function() firesignal(button.MouseButton1Down) end)
            pcall(function() firesignal(button.Activated) end)
        end
        return true
    end
    return false
end

-- Helper function to detect if Trial event is open/active
local function isTrialOpen()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    -- 1. Check active ScreenGuis for Trial notifications
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui.Enabled then
            for _, child in ipairs(gui:GetDescendants()) do
                if child:IsA("TextLabel") then
                    local text = string.lower(child.Text)
                    if string.find(text, "trial") or string.find(text, "gate") then
                        if string.find(text, "open") or string.find(text, "active") or string.find(text, "start") or string.find(text, "ready") or string.find(text, "มาแล้ว") or string.find(text, "00:00") then
                            return true
                        end
                    end
                end
            end
        end
    end
    
    -- 2. Check workspace BillboardGuis/SurfaceGuis in the lobby for trial status
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then
            for _, child in ipairs(obj:GetDescendants()) do
                if child:IsA("TextLabel") then
                    local text = string.lower(child.Text)
                    if string.find(text, "trial") or string.find(text, "gate") then
                        if string.find(text, "open") or string.find(text, "active") or string.find(text, "start") or string.find(text, "ready") or string.find(text, "00:00") then
                            return true
                        end
                    end
                end
            end
        end
    end
    
    return false
end

-- Helper function to get current arena type
local function getCurrentArenaType()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return "None" end
    
    local defenseGui = playerGui:FindFirstChild("DefenseGui")
    if defenseGui and defenseGui.Enabled then
        return "Titan"
    end
    
    local raidGui = playerGui:FindFirstChild("RaidGui")
    if raidGui and raidGui.Enabled then
        return "Raid"
    end
    
    local trialGui = playerGui:FindFirstChild("TrialGui")
    if trialGui and trialGui.Enabled then
        return "Trial"
    end
    
    -- Workspace checks
    local defenseArenas = workspace:FindFirstChild("DefenseArenas")
    if defenseArenas and #defenseArenas:GetChildren() > 0 then
        return "Titan"
    end
    
    local raidArenas = workspace:FindFirstChild("RaidArenas")
    if raidArenas and #raidArenas:GetChildren() > 0 then
        return "Raid"
    end
    
    local timeTrial = workspace:FindFirstChild("TimeTrialArenas")
    if timeTrial then
        for _, child in ipairs(timeTrial:GetChildren()) do
            if #child:GetChildren() > 1 then
                return "Trial"
            end
            local enemies = child:FindFirstChild("Enemies")
            if enemies and #enemies:GetChildren() > 0 then
                return "Trial"
            end
        end
    end
    
    -- World 5 check (acts as Trial or Gate arena when autoTrial or autoGate is active)
    if autoGate then
        local worlds = workspace:FindFirstChild("Worlds")
        if worlds and worlds:FindFirstChild("5") then
            return "Gate"
        end
    elseif autoTrial then
        local worlds = workspace:FindFirstChild("Worlds")
        if worlds and worlds:FindFirstChild("5") then
            return "Trial"
        end
    end
    
    return "None"
end

