local function getTargetEnemies()
    local enemies = {}
    local enemiesFolder = getEnemiesFolder()
    
    if enemiesFolder then
        for _, enemy in ipairs(enemiesFolder:GetChildren()) do
            if enemy:IsA("Model") and not deadBlacklist[enemy] then
                if isEnemyAlive(enemy) then
                    -- Verify if inside trial/arena (target all enemies automatically) or selected in dropdown
                    local isTrialFolder = false
                    if enemiesFolder.Parent and enemiesFolder.Parent.Parent then
                        local parentName = enemiesFolder.Parent.Parent.Name
                        if parentName == "TimeTrialArenas" or parentName == "DefenseArenas" or parentName == "RaidArenas" then
                            isTrialFolder = true
                        end
                    end
                    
                    if isTrialFolder or autoTitanDefense or autoRaid or selectedEnemies["All"] or selectedEnemies[enemy.Name] then
                        table.insert(enemies, enemy)
                    end
                end
            end
        end
    end
    return enemies
end



