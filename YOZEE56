Tabs.Items:AddButton({
    Title = "🔍 Scan Inventory Items",
    Callback = function()
        task.spawn(function()
            if Omni and Omni.Data and Omni.Data.Inventory and Omni.Data.Inventory.Items then
                local options = {}
                table.clear(allItemsMap)
                for name, amount in pairs(Omni.Data.Inventory.Items) do
                    local displayName = tostring(name)
                    allItemsMap[displayName] = amount
                    table.insert(options, displayName)
                end
                table.sort(options)
                ItemDropdown:SetValues(options)
                Fluent:Notify({ Title = "Scanner", Content = "Found " .. #options .. " types of items", Duration = 2 })
            end
        end)
    end
})

