local lastWarpTime = 0
local function warpToWorld(worldNum)
    local now = os.time()
    if now - lastWarpTime < 10 then return false end
    lastWarpTime = now
    
    local args
    if tostring(worldNum) == "5" or worldNum == "World5" then
        args = {
            {
                "World5",
                "\129"
            }
        }
    else
        args = {
            {
                tonumber(worldNum) or worldNum,
                "\135"
            }
        }
    end
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local bridgeNet2 = replicatedStorage:FindFirstChild("BridgeNet2")
    local dataRemoteEvent = bridgeNet2 and bridgeNet2:FindFirstChild("dataRemoteEvent")
    if dataRemoteEvent then
        dataRemoteEvent:FireServer(unpack(args))
        return true
    end
    return false
end

-- Helper function to check if local player has entered the target world/arena
local function isReadyToFarm()
    if autoTitanDefense then
        return getCurrentArenaType() == "Titan"
    elseif autoRaid then
        return getCurrentArenaType() == "Raid"
    elseif autoTrial then
        return getCurrentArenaType() == "Trial"
    elseif autoGate then
        -- Check if player is actually inside World 5
        local worlds = workspace:FindFirstChild("Worlds")
        local world5 = worlds and worlds:FindFirstChild("5")
        if not world5 then return false end
        
        local hrp = Character and Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        local ref = world5:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            return (hrp.Position - ref.Position).Magnitude < 1000
        end
        return false
    else
        -- Normal auto farm: check if player is actually inside selectedWorld
        local worlds = workspace:FindFirstChild("Worlds")
        local worldFolder = worlds and worlds:FindFirstChild(selectedWorld)
        if not worldFolder then return false end
        
        local hrp = Character and Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        local ref = worldFolder:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            return (hrp.Position - ref.Position).Magnitude < 1000
        end
        return false
    end
end

-- Helper function to get the current world's enemies folder path (All Worlds 1-4 use "Enemies")
local function getEnemiesFolder()
    -- If Titan Defense is active, use ONLY Defense Arenas path
    if autoTitanDefense then
        local defenseArenas = workspace:FindFirstChild("DefenseArenas")
        local world4 = defenseArenas and defenseArenas:FindFirstChild("World4")
        return world4 and world4:FindFirstChild("Enemies")
    end

    -- If Auto Raid is active, use ONLY Raid Arenas path
    if autoRaid then
        return getRaidEnemiesFolder()
    end

    -- If Auto Trial is active, use ONLY Time Trial path
    if autoTrial then
        return getTimeTrialEnemiesFolder()
    end

    -- If Auto Gate is active, use World 5 Enemies path
    if autoGate then
        local worlds = workspace:FindFirstChild("Worlds")
        local world5 = worlds and worlds:FindFirstChild("5")
        return world5 and world5:FindFirstChild("Enemies")
    end

    local worlds = workspace:FindFirstChild("Worlds")
    if not worlds then return nil end
    
    local worldFolder = worlds:FindFirstChild(selectedWorld)
    if not worldFolder then return nil end
    
    return worldFolder:FindFirstChild("Enemies")
end

