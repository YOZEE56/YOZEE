-- 9. Auto Farm Loop Execution (Physics drop + Target Lock-on & dynamic CFrame follow + Smart Blacklist + Specific Attribute Checks)
task.spawn(function()
    while true do
        task.wait()
        
        if autofarm and Character and Character:FindFirstChild("HumanoidRootPart") 
            and Character:FindFirstChild("Humanoid") and Character.Humanoid.Health > 0 
            and isReadyToFarm() then
            
            local targets = getTargetEnemies()
            local target = nil
            local closestDist = math.huge
            local myPos = Character.HumanoidRootPart.Position
            
            -- Find the closest valid enemy in selected world (filtered by multi-select targets)
            for _, enemy in ipairs(targets) do
                local enemyPos = getEnemyPosition(enemy)
                if enemyPos then
                    local dist = (enemyPos - myPos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        target = enemy
                    end
                end
            end
            
            if target then
                local targetCFrame = getEnemyCFrame(target)
                if targetCFrame then
                    -- Debug output current attributes to F9 console on target lock
                    -- debugAttributes(target)
                    
                    -- Active CFrame Follow: Keep teleporting/snapping directly onto the target's body CFrame (Titan Defense only)
                    local trackConnection
                    if autoTitanDefense then
                        trackConnection = RunService.Heartbeat:Connect(function()
                            if not autofarm or not target or not target.Parent or not isEnemyAlive(target) then
                                if trackConnection then trackConnection:Disconnect() end
                                return
                            end
                            
                            local currentEnemyCFrame = getEnemyCFrame(target)
                            if currentEnemyCFrame and Character and Character:FindFirstChild("HumanoidRootPart") then
                                -- Teleport follow directly (attaches player 3.5 studs above the target's relative CFrame)
                                Character.HumanoidRootPart.CFrame = currentEnemyCFrame * CFrame.new(followOffset)
                                Character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                            end
                        end)
                    else
                        -- Warp once immediately for normal worlds / normal trials
                        local currentEnemyCFrame = getEnemyCFrame(target)
                        if currentEnemyCFrame and Character and Character:FindFirstChild("HumanoidRootPart") then
                            Character.HumanoidRootPart.CFrame = currentEnemyCFrame * CFrame.new(followOffset)
                            Character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                        end
                    end
                    
                    -- Target Lock Attack Loop: Farm THIS specific target until it dies
                    while autofarm and target and target.Parent and isEnemyAlive(target) do
                        -- Static Teleport for non-Titan farm modes (normal worlds / normal trials)
                        if not trackConnection then
                            local currentEnemyCFrame = getEnemyCFrame(target)
                            if currentEnemyCFrame and Character and Character:FindFirstChild("HumanoidRootPart") then
                                Character.HumanoidRootPart.CFrame = currentEnemyCFrame * CFrame.new(followOffset)
                                Character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                            end
                        end

                        -- Auto Equip Active Tool
                        if autoEquip then
                            local backpack = LocalPlayer:FindFirstChild("Backpack")
                            if backpack then
                                for _, tool in ipairs(backpack:GetChildren()) do
                                    if tool:IsA("Tool") then
                                        Character.Humanoid:EquipTool(tool)
                                        break
                                    end
                                end
                            end
                        end
                        
                        -- Auto Attack trigger
                        if autoAttack then
                            local equippedTool = Character:FindFirstChildOfClass("Tool")
                            if equippedTool then
                                equippedTool:Activate()
                            else
                                -- Fallback: Use virtual click if no tool is held
                                VirtualUser:Button1Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
                            end
                        end
                        
                        task.wait(attackDelay)
                    end
                    
                    -- Clean up dynamic CFrame connection when target dies
                    if trackConnection then
                        trackConnection:Disconnect()
                    end
                    
                    -- Add target to dead blacklist for 5 seconds to avoid getting stuck on its dead body
                    deadBlacklist[target] = true
                    task.spawn(function()
                        task.wait(5)
                        deadBlacklist[target] = nil
                    end)
                end
            else
                task.wait(0.5)
            end
        end
    end
end)

