}

for _, cfg in ipairs(worlds) do
    local T = Tabs.OpFarm:AddToggle("Farm"..cfg.name, {Title = "op farm " .. cfg.name, Default = false})
    T:OnChanged(function()
        task.spawn(function()
            local remote = game:GetService("ReplicatedStorage").BridgeNet.dataRemoteEvent
            while T.Value do
                local currentMode = Omni and Omni.Data and Omni.Data.Mode or ""
                if currentMode == "Tempest Invasion" then task.wait(2)
                else
                    if Omni and (Omni.Data.Map ~= cfg.MapName or Omni.Data.Zone ~= cfg.ZoneIndex) then
                        remote:FireServer({{ "Player", "Teleport", "Teleport", cfg.MapName, cfg.ZoneIndex, n = 5 }, "\x02"})
                        repeat task.wait(1) until (Omni.Data.Map == cfg.MapName and Omni.Data.Zone == cfg.ZoneIndex) or not T.Value
                        task.wait(2)
                    end
                    for _, target in ipairs(cfg.points) do
                        if not T.Value or (Omni and Omni.Data.Mode == "Tempest Invasion") or (Omni and Omni.Data.Map ~= cfg.MapName) then break end
                        local hrp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if hrp and game.Players.LocalPlayer.Character.Humanoid.Health > 0 then
                            hrp.CFrame = target
                            task.wait(opWaitTime)
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end)
end

