local RerollTab = Window:Tab({ Title = "Reroll", Icon = "dices" })
local function CreateAutoRoll(title, typeName, nValue)
    local toggleEnabled = false
    local RollToggle = RerollTab:Toggle({
        Title = title, Desc = "Auto roll", Value = false,
        Callback = function(state)
            toggleEnabled = state
            task.spawn(function()
                local remote = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
                while toggleEnabled do
                    if title == "Auto Roll Sword" then remote:FireServer({{"General", "Banner", "Roll", typeName, n = nValue}, "\x02"})
                    else remote:FireServer({{"General", "Gacha", "Roll", typeName, {}, n = nValue}, "\x02"}) end
                    task.wait(0.5)
                end
            end)
        end
    })
    if myConfig then myConfig:Register(title:gsub(" ", "_"), RollToggle) end
end
