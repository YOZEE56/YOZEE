-- ==========================================
-- 🔨 Tab 3: Forge
-- ==========================================
local ForgeTab = Window:Tab({
    Title = "Forge",
    Icon = "hammer"
})

ForgeTab:Button({
    Title = "Craft Luffe",
    Desc = "คราฟดิควย",
    Icon = "hammer",
    Callback = function()
        local remoteEvent = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
        
        -- ส่งคำสั่งคราฟต์ไปยังเซิร์ฟเวอร์
        remoteEvent:FireServer({
            {
                "General",
                "PassivePunks",
                "Forge",
                "a10685fc-86c6-497c-9af3-29a6d0a2fabf", -- รหัสของ Luffe
                {
                    { Name = "Wood Katana", Amount = 10 },
                    { Name = "Diamond", Amount = 6 }
                },
                n = 5
            },
            "\x02"
        })

        -- แจ้งเตือนเมื่อกดปุ่ม
        WindUI:Notify({
            Title = "Forge System",
            Content = "Crafting Luffe!",
            Duration = 3,
            Icon = "check"
        })
    end
})

-- ==========================================
-- ⚙️ Tab 4: Settings
-- ==========================================
local SettingsTab = Window:Tab({
    Title = "Settings",
    Icon = "settings"
})

SettingsTab:Keybind({
    Title = "Toggle UI",
    Desc = "Set your UI toggle bind.",
    Value = "RightShift",
    Callback = function(Key)
        Window:SetToggleKey(Enum.KeyCode[Key])
        WindUI:Notify({
            Title = "Settings",
            Content = "Toggle key set to " .. Key,
            Duration = 3,
            Icon = "settings"
        })
    end
})

SettingsTab:Button({
    Title = "Unload UI",
    Desc = "Complete",
    Icon = "log-out",
    Callback = function()
        -- Stop all loops before unloading to prevent memory leaks or crashes
        autoRollHakiEnabled = false
        autoRollFruitEnabled = false
        autoRollSwordEnabled = false
        autoRollRaceEnabled = false
        autoRollDragonPowerEnabled = false
        autoRollSlimePowerEnabled = false
        Window:Destroy()
    end
})
