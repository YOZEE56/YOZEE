-- Helper function to check if a task is available in the queue
local function isTaskAvailable(taskName)
    if taskName == "None" then
        return false
    elseif taskName == "Auto Trial" then
        local currentArena = getCurrentArenaType()
        if currentArena == "Trial" then
            return true
        end
        if trialIsEventOnly then
            return isTrialOpen()
        else
            return not completedTasks["Auto Trial"]
        end
    elseif taskName == "Auto Titan" then
        if isTrialOpen() then
            return false
        end
        return not completedTasks["Auto Titan"]
    elseif taskName == "Auto Raid" then
        if isTrialOpen() then
            return false
        end
        return not completedTasks["Auto Raid"]
    elseif taskName == "Auto Gate" then
        if isTrialOpen() then
            return false
        end
        return not completedTasks["Auto Gate"]
    elseif taskName == "Auto Farm" then
        if isTrialOpen() then
            return false
        end
        return true
    end
    return false
end

-- Helper function to check and reset queue completion flags
local function checkResetQueue()
    local allCompleted = true
    local hasTrackedTasks = false
    
    for i = 1, 5 do
        local taskName = priorityQueue[i]
        if taskName == "Auto Titan" or taskName == "Auto Raid" or taskName == "Auto Gate" or (taskName == "Auto Trial" and not trialIsEventOnly) then
            hasTrackedTasks = true
            if not completedTasks[taskName] then
                allCompleted = false
            end
        end
    end
    
    if hasTrackedTasks and allCompleted then
        completedTasks["Auto Titan"] = false
        completedTasks["Auto Raid"] = false
        completedTasks["Auto Trial"] = false
        completedTasks["Auto Gate"] = false
        print("[Priority Queue] All queue tasks completed. Resetting queue cycle.")
    end
end

