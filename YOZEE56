-- ==========================================
-- 🔨 Tab: Forge (With Status Check)
-- ==========================================
local memUnits = {}
local unitLockStatus = {}
local selectedMemUUID = ""

local StatusLabel = Tabs.Forge:AddParagraph({
    Title = "Selected Unit Status",
    Content = "Please scan and select a unit"
})

local ForgeDropdown = Tabs.Forge:AddDropdown("ForgeDropdown", {
    Title = "Select Unit",
    Values = {"Waiting for scan..."},
    Multi = false, Default = 1,
    Callback = function(Value)
        selectedMemUUID = memUnits[Value] or ""
        local status = unitLockStatus[Value] or "Unknown"
        StatusLabel:SetTitle("Unit Status: " .. status) -- แสดงสถานะล็อก/ไม่ล็อก
    end
})

Tabs.Forge:AddButton({
    Title = "🔍 Scan Units",
    Callback = function()
        task.spawn(function()
            local options = {}
            table.clear(memUnits)
            table.clear(unitLockStatus)
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" then
                    pcall(function()
                        if rawget(v, "Inventory") and type(rawget(v, "Inventory")) == "table" and rawget(rawget(v, "Inventory"), "Units") then
                            for uid, unitData in pairs(v.Inventory.Units) do
                                local name = tostring(unitData.Name)
                                local isLocked = rawget(unitData, "Locked")
                                local lockText = isLocked and "Locked 🔒" or "Unlocked 🔓"
                                local display = name .. " | " .. string.sub(tostring(uid), 1, 6)
                                
                                memUnits[display] = uid
                                unitLockStatus[display] = lockText
                                table.insert(options, display)
                            end
                        end
                    end)
                end
            end
            if #options > 0 then
                table.sort(options)
                ForgeDropdown:SetValues(options)
            end
        end)
    end
})

