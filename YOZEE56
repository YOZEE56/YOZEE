                    completedTaskName = "Auto Raid"
                elseif lastArenaType == "Trial" then
                    completedTaskName = "Auto Trial"
                elseif lastArenaType == "Gate" then
                    completedTaskName = "Auto Gate"
                end
                
                if completedTaskName then
                    completedTasks[completedTaskName] = true
                    WindUI:Notify({
                        Title = "Priority Queue",
                        Content = completedTaskName .. " completed. Loading lobby...",
                        Icon = "check-circle",
                        Duration = 3
                    })
                end
                
                -- Check if we need to reset flags
                checkResetQueue()
                
                -- Wait 4 seconds for lobby assets and ScreenGuis to fully load
                task.wait(4)
            end
            
            lastArenaType = currentArena
            
            -- Find best task
            local bestTask = "None"
            local bestIndex = 99
            
            for i = 1, 5 do
                local taskName = priorityQueue[i]
                if isTaskAvailable(taskName) then
                    bestTask = taskName
                    bestIndex = i
                    break
                end
            end
            
            -- Determine current running task name
            local currentRunningTask = "None"
            if currentArena == "Titan" then
