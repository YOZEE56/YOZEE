-- Load WindUI Library
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()

-- Create Main Window
local Window = WindUI:CreateWindow({
    Title = "YOZEE Script",
    Icon = "swords", 
    Author = "YOZEE",
    Size = UDim2.new(0, 500, 0, 400),
    Transparent = true,
    Theme = "Dark",
    ToggleKey = Enum.KeyCode.RightShift
})

-- ==========================================
-- ⚔️ Tab 1: Main Features
-- ==========================================
local MainTab = Window:Tab({
    Title = "Main Features",
    Icon = "home"
})

MainTab:Button({
    Title = "Remove Gacha UI",
    Desc = "Instantly remove the GachaAnimation from your screen.",
    Icon = "trash",
    Callback = function()
        local player = game.Players.LocalPlayer
        local playerGui = player:WaitForChild("PlayerGui")
        local gachaAnim = playerGui:FindFirstChild("GachaAnimation")

        if gachaAnim and gachaAnim:FindFirstChild("Main") then
            gachaAnim.Main:Destroy()
            WindUI:Notify({
                Title = "YOZEE Script",
                Content = "Gacha UI removed!",
                Duration = 3,
                Icon = "check"
            })
        else
            WindUI:Notify({
                Title = "Error",
                Content = "Gacha UI not found.",
                Duration = 3,
                Icon = "x"
            })
        end
    end
})

-- ==========================================
-- 🎲 Tab 2: Reroll
-- ==========================================
local RerollTab = Window:Tab({
    Title = "Reroll",
    Icon = "dices"
})

-- Variables to control the auto roll loops
local autoRollHakiEnabled = false
local autoRollFruitEnabled = false
local autoRollSwordEnabled = false
local autoRollRaceEnabled = false
local autoRollDragonPowerEnabled = false
local autoRollSlimePowerEnabled = false

RerollTab:Toggle({
    Title = "Auto Roll Haki",
    Desc = "กดสุ่มดิควย",
    Value = false,
    Callback = function(state)
        autoRollHakiEnabled = state
        if autoRollHakiEnabled then
            task.spawn(function()
                local remoteEvent = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
                while autoRollHakiEnabled do
                    remoteEvent:FireServer({{"General", "Gacha", "Roll", "Haki", {}, n = 5}, "\x02"})
                    task.wait(0.5) 
                end
            end)
        end
    end
})

