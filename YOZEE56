-- 🎲 Tab: Reroll (Complete List)
-- ==========================================
local function AddRoll(title, typeName, n, rollType)
    local T = Tabs.Reroll:AddToggle(title, {Title = title, Default = false})
    T:OnChanged(function()
        task.spawn(function()
            local remote = game:GetService("ReplicatedStorage").BridgeNet.dataRemoteEvent
            while T.Value do
                if rollType == "Banner" then
                    remote:FireServer({{"General", "Banner", "Roll", typeName, n = n}, "\x02"})
                elseif rollType == "Roulette" then
                    remote:FireServer({{"General", "Roulette", "Roll", typeName, n = n}, "\x02"})
                else
                    remote:FireServer({{"General", "Gacha", "Roll", typeName, {}, n = n}, "\x02"})
                end
                task.wait(0.5)
            end
        end)
    end)
end

