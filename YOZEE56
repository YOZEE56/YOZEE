-- 📦 Tab 6: Misc (Smart Rewards)
-- ==========================================
local MiscTab = Window:Tab({ Title = "Misc", Icon = "box" })
local autoClaimEnabled = false
local ClaimToggle = MiscTab:Toggle({
    Title = "Auto Claim & Reset Rewards",
    Desc = "Claim 1-7 and Reset",
    Value = false,
    Callback = function(state)
        autoClaimEnabled = state
        task.spawn(function()
            local remote = game:GetService("ReplicatedStorage"):WaitForChild("BridgeNet"):WaitForChild("dataRemoteEvent")
            while autoClaimEnabled do
                pcall(function()
                    local data = Omni.Data.TimeRewards
                    local allClaimed = true
                    for i = 1, 7 do
                        if not data.Claimed[tostring(i)] then
                            allClaimed = false
                            if data.TimePlayed >= Omni.Shared.TimeRewards[i].Time then
                                remote:FireServer({{ "General", "TimeRewards", "Claim", i }, "\x02"})
                                task.wait(1.5)
                            end
                        end
                    end
                    if allClaimed then
                        remote:FireServer({{[1] = "General", [2] = "TimeRewards", [3] = "Reset"}, "\x02"})
                        task.wait(2)
                    end
                end)
                task.wait(3)
            end
        end)
    end
})
if myConfig then myConfig:Register("Auto_Claim_Reset", ClaimToggle) end

